{
  "name": "table-initializer",
  "version": "1.0.0",
  "description": "DynamoDB table initializer from tenants-config.json",
  "type": "module",
  "main": "index.mjs",
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.0.0",
    "@aws-sdk/client-secretsmanager": "^3.0.0"
  },
  "scripts": {
    "build": "rm -rf dist && esbuild ./*.mjs --entry-names=./[name] --bundle --minify --sourcemap --platform=node --target=node20.16 --outdir=dist --external:@aws-sdk/* --external:admin-auth"
  },
  "devDependencies": {
    "esbuild": "^0.25.0"
  }
}
